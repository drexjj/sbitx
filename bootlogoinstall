#!/bin/bash

# Exit immediately on error, undefined vars, or pipe failures
set -euo pipefail

# Configuration
SOURCE="/home/pi/Pictures/sbitxv54.png"
DEST_DIR="/usr/share/plymouth/themes/pix"
DEST_FILE="splash.png"
DESTINATION="${DEST_DIR}/${DEST_FILE}"
THEME_NAME="pix"

# Colors for output (optional, works in most terminals)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print status messages
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Cleanup function to remove temp files on exit
TEMP_FILE=""
cleanup() {
    if [[ -n "$TEMP_FILE" && -f "$TEMP_FILE" ]]; then
        rm -f "$TEMP_FILE"
        log_warn "Cleaned up temporary file: $TEMP_FILE"
    fi
}
trap cleanup EXIT

# 1. Validate Source File
if [[ ! -f "$SOURCE" ]]; then
    log_error "Source file '$SOURCE' does not exist. Aborting."
    exit 1
fi

# Basic PNG header check (optional but recommended)
if ! head -c 8 "$SOURCE" | grep -q $'\x89PNG\r\n\x1a\n'; then
    log_error "Source file '$SOURCE' does not appear to be a valid PNG image. Aborting."
    exit 1
fi

log_info "Source file validated: $SOURCE"

# 2. Create Temporary File for Atomic Copy
# We copy to a temp file first to avoid corrupting the live splash if interrupted
TEMP_FILE=$(mktemp /tmp/splash_update.XXXXXX)
log_info "Created temporary file: $TEMP_FILE"

if ! cp "$SOURCE" "$TEMP_FILE"; then
    log_error "Failed to copy source to temporary file. Aborting."
    exit 1
fi

# 3. Backup Existing Splash
if [[ -f "$DESTINATION" ]]; then
    log_info "Backing up existing splash image..."
    sudo cp "$DESTINATION" "${DESTINATION}.bak.$(date +%F_%H%M%S)"
    if [[ $? -ne 0 ]]; then
        log_error "Failed to create backup. Aborting to prevent data loss."
        exit 1
    fi
else
    log_warn "No existing splash image found at $DESTINATION. Skipping backup."
fi

# 4. Replace Splash Image Atomically
log_info "Replacing splash image..."
if ! sudo mv "$TEMP_FILE" "$DESTINATION"; then
    log_error "Failed to move new image to destination. Aborting."
    exit 1
fi
# Clear TEMP_FILE variable so cleanup doesn't try to delete the now-moved file
TEMP_FILE=""

log_info "Splash image replaced successfully."

# 5. Rebuild Initrd
log_info "Rebuilding initrd for theme '$THEME_NAME'..."
if sudo plymouth-set-default-theme --rebuild-initrd "$THEME_NAME"; then
    log_info "Initrd rebuilt successfully."
else
    log_error "Failed to rebuild initrd! Your splash screen may not update on next boot."
    log_error "Consider restoring the backup: sudo cp ${DESTINATION}.bak.* ${DESTINATION}"
    exit 1
fi

log_info "Operation completed successfully! Please reboot to see changes."
log_info "Command: sudo reboot"   